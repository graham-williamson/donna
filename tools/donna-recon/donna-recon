#!/bin/sh
# donna-recon launcher — runs the CLI from the sibling .venv.
# Graham: `chmod +x` me once after first git clone.
set -eu
DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PY="$DIR/.venv/bin/python"
if [ ! -x "$VENV_PY" ]; then
    echo "donna-recon: .venv/bin/python not found at $VENV_PY" >&2
    echo "             run 'python3 -m venv .venv && .venv/bin/pip install -r requirements.txt' first." >&2
    exit 1
fi
exec "$VENV_PY" -m donna_recon "$@"
