# Diagnostic sink for new-tab following. Set to a file path in main() once the
# run dir exists; _tablog() appends one line per click so we can see, post-run,
# exactly what the tab-follow observed (target/href, popups seen, page switches).
_TABFOLLOW_LOG: str | None = None

# Playwright's TimeoutError, bound in main() once Playwright is imported (the
# module must import WITHOUT Playwright for the pure-helper tests, so we can't
# import it at top level). Until bound it falls back to Exception.
PWTimeout: type = Exception


def _tablog(msg: str) -> None:
    if not _TABFOLLOW_LOG:
        return
    try:
        with open(_TABFOLLOW_LOG, "a", encoding="utf-8") as f:
            f.write(msg + "\n")
    except Exception:
        pass


def _is_cross_host(cur: str, href: str) -> bool:
    """True iff href is an absolute URL on a DIFFERENT host than cur. Such a link
    opens a new tab/navigation we must follow; same-host or relative hrefs don't."""
    if not href or not href.lower().startswith(("http://", "https://")):
        return False
    try:
        from urllib.parse import urlparse
        return urlparse(cur).netloc != urlparse(href).netloc
    except Exception:
        return False


def _safe_dest(href: str, base_url: str) -> str:
    """Where a link GOES, as 'host/path' — for the agent's link tree, so it picks
    real links by destination instead of GUESSING navigate paths (the failure mode
    behind every dead-end 404 so far). Resolves relative hrefs against base_url and
    STRIPS the query string + fragment, so session tokens (e.g. the EA SSO
    ?token=… landing url) never enter the agent's context. Returns '' for
    javascript:/mailto:/#-only links the agent can't usefully target."""
    if not href:
        return ""
    try:
        from urllib.parse import urljoin, urlparse
        absu = urljoin(base_url, href.strip())
        p = urlparse(absu)
        if p.scheme not in ("http", "https"):
            return ""
        path = p.path or "/"
        return f"{p.netloc}{path}"
    except Exception:
        return ""


