def fail(error_code: str, detail: str) -> None:
    """Write a structured failure envelope to stdout and exit 1."""
    json.dump({"error_code": error_code, "detail": detail}, sys.stdout)
    sys.stdout.flush()
    sys.exit(1)


def _accessibility_to_snapshot(url: str, raw_nodes: list) -> dict:
    """Convert a list of accessibility/DOM node dicts to a normalised snapshot dict.

    Pure — no browser interaction. Used by _PlaywrightBrowser.snapshot() and
    directly unit-tested in tests/test_browser_goal_executor.py.

    Each node in raw_nodes may contain: ref, role, name, tag, editable.
    Missing refs are assigned stable enumerated ids.
    """
    nodes = []
    for i, node in enumerate(raw_nodes or []):
        ref = str(node.get("ref") or "").strip() or f"n{i}"
        out = {
            "ref": ref,
            "role": str(node.get("role") or "generic"),
            "name": str(node.get("name") or ""),
            "tag": str(node.get("tag") or ""),
            "editable": bool(node.get("editable")),
        }
        # Carry the link tree / dropdown options through, only when present, so
        # snapshots without them are byte-identical to before.
        if node.get("dest"):
            out["dest"] = str(node.get("dest"))[:120]
        if node.get("options"):
            out["options"] = [str(o)[:80] for o in node.get("options")][:60]
        nodes.append(out)
    return {"url": url, "nodes": nodes}


def read_params() -> dict:
    """Read JSON {capability, params} from stdin; return the inner params dict."""
    request = json.load(sys.stdin)
    return request["params"]


def read_creds() -> dict:
    """Read decrypted credential bytes from the DONNA_CREDS_FD pipe.

    The fd number is in the DONNA_CREDS_FD env var, set by the broker before
    exec. Credentials never touch Donna's context — they live only here, in the
    executor subprocess, from this read until the fd is closed.
    """
    fd_str = os.environ.get("DONNA_CREDS_FD")
    if fd_str is None:
        fail("login_failed", "DONNA_CREDS_FD not set")
    fd = int(fd_str)
    data = b""
    while True:
        chunk = os.read(fd, 65536)
        if not chunk:
            break
        data += chunk
    os.close(fd)
    return json.loads(data)


def _profile_search_paths(site: str) -> list:
    """Where to look for a site profile, in priority order:

    1. The live CONFIG dir (~/.config/donna/profiles) — where the signed
       promoter installs app-onboarded profiles (config_dir/profiles, per
       promoter_fs). This is the canonical install location.
    2. The CODE dir (manifests/profiles, beside the executor) — profiles shipped
       with the broker itself (e.g. everyone_active), synced via the code rsync.

    HOME is set to the donna-broker account by the broker's sanitised env, so
    Path.home() resolves to /Users/donna-broker.
    """
    name = f"{site}.json"
    return [
        Path.home() / ".config" / "donna" / "profiles" / name,
        Path(__file__).resolve().parents[1] / "manifests" / "profiles" / name,
    ]


def _load_profile(site: str) -> "browser_profile.SiteProfile":
    """Load and validate the site profile JSON for <site>, searching the install
    locations in priority order (see _profile_search_paths).

    Raises SystemExit (via fail()) if the file is missing or the profile is
    malformed (fail-closed).
    """
    profile_path = next((p for p in _profile_search_paths(site) if p.exists()), None)
    if profile_path is None:
        fail("profile_not_found",
             f"no profile for {site!r} in the config dir "
             f"(~/.config/donna/profiles) or the code dir (manifests/profiles) — "
             f"install the site profile before running this executor")
    try:
        raw = json.loads(profile_path.read_text(encoding="utf-8"))
    except Exception as exc:
        fail("profile_not_found", f"could not parse site profile: {exc}")
    try:
        return browser_profile.load(raw)
    except browser_profile.ProfileError as exc:
        fail("profile_not_found", f"site profile validation failed: {exc}")


# ---------------------------------------------------------------------------
# _PlaywrightBrowser — the live adapter. Playwright import is INSIDE this class
# so the module can be imported without Playwright for the pure-helper tests.
# ---------------------------------------------------------------------------

class _PlaywrightBrowser:
    """Playwright adapter implementing the BrowserLike protocol (browser_runner).

    Invariants:
      - context.route handler aborts any request whose URL fails the allowlist
        (invariant 5, network layer).
      - Under network_strictness == "hard_abort", also aborts non-idempotent
        requests (POST/PUT/PATCH/DELETE) unless a commit token is live.
        Under "monitor", those requests are allowed (best-effort; the gate is
        the primary commit-token authority).
      - Credential substitution for {{cred:*}} placeholders happens HERE in
        execute(), not in the agent. The agent receives placeholder strings and
        never sees the real secret.
    """

    _CRED = re.compile(r"\{\{cred:(username|password)\}\}")
    _MUTATING_METHODS = frozenset({"POST", "PUT", "PATCH", "DELETE"})

    def __init__(self, page, context, allowlist: tuple, strictness: str,
                 creds: dict) -> None:
        self._page = page
        self._context = context
        self._allowlist = allowlist
        self._strictness = strictness
        self._creds = creds
        # Install the network-layer allowlist filter.
        context.route("**/*", self._route_handler)

    def _adopt_popup(self, popup) -> None:
        """Switch the active page to a popup deterministically captured by
        expect_page(), once it has settled on a real (non about:blank) url. SSO
        booking flows (EA -> Legend) chain redirects, so wait a few seconds for
        the popup to land before snapshotting it."""
        try:
            for _ in range(20):            # up to ~4s for redirect chains
                try:
                    popup.wait_for_load_state("domcontentloaded", timeout=4000)
                except Exception:
                    pass
                if popup.url and not popup.url.startswith("about:"):
                    break
                try:
                    popup.wait_for_timeout(200)
                except Exception:
                    break
            if popup.is_closed():
                _tablog("  popup closed before adopt")
                return
            self._page = popup
            _tablog(f"  adopted popup url={popup.url[:90]!r}")
        except Exception as e:               # noqa: BLE001
            _tablog(f"  adopt error {type(e).__name__}: {e}")

    def _follow_new_tab(self, pages_before: set, *, generous: bool = False) -> None:
        """If the last click opened a NEW tab/window, switch the adapter's active
        page to it. Called SYNCHRONOUSLY right after a click — not via an async
        context 'page' event, which would race the snapshot/execute boundary and
        could switch onto a transient about:blank mid-login. Many flows (a booking
        site on a different subdomain) open in a new tab; without following it,
        every click looks like a no-op and the agent loops. The context.route
        allowlist still covers the new page, so it stays network-gated.

        A target=_blank / window.open popup does NOT appear in context.pages
        synchronously when click() returns — it registers a few hundred ms later.
        So we POLL for it rather than checking once (the single-check version
        silently missed every new-window link, e.g. EA's 'Make or Manage
        bookings', and the agent clicked the dead link until timeout). ``generous``
        is set when the clicked element declared target=_blank: we then wait
        longer, since a new tab is expected. Otherwise we poll briefly to catch a
        JS-opened popup without penalising the common in-page click."""
        try:
            target = None
            polls = 20 if generous else 4   # ~2.0s vs ~0.4s at 100ms
            for _ in range(polls):
                new_pages = [p for p in self._context.pages
                             if p not in pages_before and not p.is_closed()]
                if new_pages:
                    target = new_pages[-1]
                    break
                try:
                    self._page.wait_for_timeout(100)
                except Exception:
                    break
            if target is None:
                return
            # Wait for the popup to settle on its REAL url, not the transient
            # about:blank a _blank tab starts on.
            for _ in range(15):            # up to ~3s
                try:
                    target.wait_for_load_state("domcontentloaded", timeout=4000)
                except Exception:
                    pass
                if target.url and not target.url.startswith("about:"):
                    break
                try:
                    target.wait_for_timeout(200)
                except Exception:
                    break
            if target.url and not target.url.startswith("about:"):
                self._page = target
        except Exception:
            pass

    def _route_handler(self, route) -> None:
        """Abort off-allowlist requests and (under hard_abort) unguarded mutations."""
        try:
            url = route.request.url
            method = (route.request.method or "GET").upper()

            if not browser_nav.is_allowed(url, self._allowlist):
                route.abort()
                return

            if (self._strictness == "hard_abort"
                    and method in self._MUTATING_METHODS):
                # No commit-token tracking here — the gate is the authority.
                # Under hard_abort we are conservative: abort mutations that
                # weren't preceded by an explicit gate-approved execute().
                # This is best-effort; the gate already refuses committing
                # actions without a token before execute() is called.
                route.abort()
                return

            route.continue_()
        except Exception:
            # Playwright aborts automatically if we don't respond; play safe.
            try:
                route.continue_()
            except Exception:
                pass

    def snapshot(self) -> dict:
        """Return a normalised snapshot of the current page's accessibility tree."""
        # Let the page settle so we snapshot the RENDERED DOM, not a still-loading
        # state. domcontentloaded + a brief fixed pause — NOT networkidle, which
        # never fires on live booking/app pages (persistent/polling connections)
        # and would burn its full timeout on every snapshot, blowing the executor
        # budget. The short pause lets late JS render.
        try:
            self._page.wait_for_load_state("domcontentloaded", timeout=8000)
        except Exception:
            pass
        try:
            self._page.wait_for_timeout(400)
        except Exception:
            pass
        url = self._page.url
        try:
            # Playwright's accessibility snapshot returns a tree; we flatten it.
            raw_tree = self._page.accessibility.snapshot()
            raw_nodes = self._flatten_tree(raw_tree or {})
        except Exception:
            raw_nodes = []

        # Augment with interactable elements for fuller coverage.
        try:
            interactable = self._page.query_selector_all(
                "a[href], button, input, select, textarea, [role='button'], "
                "[role='link'], [role='textbox'], [role='checkbox']"
            )
            seen_refs = {n.get("ref") for n in raw_nodes if n.get("ref")}
            for i, el in enumerate(interactable):
                # Only surface elements the agent can actually act on. Hidden
                # elements (display:none, behind an un-dismissed overlay, in a
                # collapsed menu) stay in the DOM but produce "not visible"
                # click/type timeouts. Skip them — the ref keeps the RAW index i
                # so _find_element re-locates the SAME element by index.
                try:
                    if not el.is_visible():
                        continue
                except Exception:
                    continue
                role = (el.get_attribute("role") or el.evaluate(
                    "el => el.tagName.toLowerCase()") or "element")
                name = (el.get_attribute("aria-label")
                        or el.get_attribute("placeholder")
                        or el.text_content()
                        or el.get_attribute("value")
                        or "")
                tag = el.evaluate("el => el.tagName.toLowerCase()") or ""
                editable = tag in ("input", "textarea", "select") or bool(
                    el.get_attribute("contenteditable"))
                ref = f"el{i}"
                if ref not in seen_refs:
                    node = {
                        "ref": ref,
                        "role": str(role),
                        "name": str(name).strip()[:200],
                        "tag": str(tag),
                        "editable": editable,
                    }
                    # Link tree: show where each link GOES so the agent clicks the
                    # right one instead of guessing a navigate path.
                    if tag == "a":
                        try:
                            dest = _safe_dest(el.get_attribute("href") or "", url)
                            if dest:
                                node["dest"] = dest
                        except Exception:
                            pass
                    # Dropdown: surface the selectable option labels so the agent
                    # knows the exact text to pass to 'select'.
                    if tag == "select":
                        try:
                            opts = el.evaluate(
                                "s => Array.from(s.options).map(o => o.text.trim())"
                                ".filter(Boolean).slice(0, 60)") or []
                            if opts:
                                node["options"] = [str(o)[:80] for o in opts]
                        except Exception:
                            pass
                    raw_nodes.append(node)
                    seen_refs.add(ref)
        except Exception:
            pass

        # Capture the page's visible TEXT as one element so the agent can READ
        # content (a class timetable, an error/404 message) — the interactable
        # elements above only let it click, not read. innerText strips scripts.
        try:
            body_text = self._page.evaluate(
                "() => (document.body && document.body.innerText) || ''")
            if body_text and body_text.strip():
                raw_nodes.append({
                    "ref": "_pagetext",
                    "role": "page_text",
                    "name": str(body_text).strip()[:8000],
                    "tag": "text",
                    "editable": False,
                })
        except Exception:
            pass

        return _accessibility_to_snapshot(url, raw_nodes)

    @staticmethod
    def _flatten_tree(node: dict, depth: int = 0, out: list | None = None,
                      counter: list | None = None) -> list:
        """Recursively flatten an accessibility tree into a list of node dicts."""
        if out is None:
            out = []
        if counter is None:
            counter = [0]
        if not isinstance(node, dict):
            return out
        role = str(node.get("role") or "")
        name = str(node.get("name") or "")
        if role and role not in ("RootWebArea", "WebArea", "none", "generic"):
            ref = f"a{counter[0]}"
            counter[0] += 1
            out.append({
                "ref": ref,
                "role": role,
                "name": name,
                "tag": "",
                "editable": role.lower() in ("textbox", "searchbox", "spinbutton",
                                              "combobox"),
            })
        for child in node.get("children") or []:
            _PlaywrightBrowser._flatten_tree(child, depth + 1, out, counter)
        return out

    def execute(self, action: dict) -> None:
        """Execute a gate-approved action on the live page.

        Dispatches:
          navigate — page.goto the resolved URL (gate already validated it)
          click    — click the element for action["ref"]
          type     — fill the element; {{cred:*}} is substituted HERE from
                     the fd creds — the ONLY place the real secret exists.

        read/done/give_up actions are no-ops for the browser layer (handled
        by the runner's state machine).
        """
        kind = action.get("kind")

        if kind == "navigate":
            url = str(action.get("url") or "")
            try:
                # domcontentloaded (not the default 'load'/networkidle) — fast and
                # reliable; the next snapshot's settle handles late render.
                self._page.goto(url, timeout=30000, wait_until="domcontentloaded")
            except Exception as exc:
                fail("navigation_failed", f"navigate to {url!r}: {type(exc).__name__}: {exc}")

        elif kind == "click":
            ref = str(action.get("ref") or "")
            el = self._find_element(ref)
            if el is None:
                fail("unexpected_dom", f"click target {ref!r} not found on page")
            try:
                el.scroll_into_view_if_needed(timeout=4000)
            except Exception:
                pass
            pages_before = set(self._context.pages)
            # Read the link's target/href BEFORE clicking. A target=_blank link —
            # or an href to a different host than the current page — opens a NEW
            # TAB rather than navigating in place (EA's 'Make or Manage bookings'
            # is an <a target=_blank> to the Legend booking site). For those we
            # capture the popup DETERMINISTICALLY with expect_page() instead of
            # racing context.pages after the click returns.
            tgt = href = ""
            try:
                tgt = el.get_attribute("target") or ""
            except Exception:
                pass
            try:
                href = el.get_attribute("href") or ""
            except Exception:
                pass
            cur = self._page.url
            expect_popup = (tgt == "_blank") or _is_cross_host(cur, href)
            _tablog(f"CLICK ref={ref!r} target={tgt!r} href={href[:80]!r} "
                    f"cur={cur[:60]!r} expect_popup={expect_popup} "
                    f"pages_before={len(pages_before)}")
            popup = None
            try:
                if expect_popup:
                    # Deterministic: wait for the page event the click triggers.
                    with self._context.expect_page(timeout=10000) as pi:
                        el.click(timeout=10000)
                    popup = pi.value
                else:
                    el.click(timeout=10000)
            except PWTimeout:
                # expect_page timed out — no popup actually opened; the click
                # still happened. Fall through to the poll as a backstop.
                _tablog("  expect_page TIMEOUT (no popup) — falling back to poll")
            except Exception as exc:
                fail("unexpected_dom", f"click {ref!r}: {type(exc).__name__}: {exc}")
            if popup is not None:
                self._adopt_popup(popup)
            else:
                # In-place click, or a popup we didn't predict — poll briefly.
                self._follow_new_tab(pages_before, generous=expect_popup)
            _tablog(f"  -> active page now {self._page.url[:80]!r}")

        elif kind == "type":
            ref = str(action.get("ref") or "")
            raw_text = str(action.get("text") or "")
            # Substitute credential placeholders — real secret lives ONLY here.
            real_text = self._CRED.sub(
                lambda m: self._creds.get(m.group(1), ""), raw_text
            )
            el = self._find_element(ref)
            if el is None:
                fail("unexpected_dom", f"type target {ref!r} not found on page")
            try:
                el.scroll_into_view_if_needed(timeout=4000)
            except Exception:
                pass
            # A <select> dropdown can't be fill()ed — you choose an option. The
            # agent uses 'type' with the option's visible label (e.g. 'Chesham
            # Leisure Centre'); drive it with select_option, matching by label
            # then by value as a fallback. This is how the agent picks a centre /
            # activity / date on a booking app's native dropdowns.
            is_select = False
            try:
                is_select = (el.evaluate("e => e.tagName.toLowerCase()") == "select")
            except Exception:
                pass
            if is_select:
                try:
                    el.select_option(label=real_text, timeout=10000)
                except Exception:
                    try:
                        el.select_option(value=real_text, timeout=10000)
                    except Exception as exc:
                        fail("unexpected_dom",
                             f"select {ref!r}={real_text!r}: {type(exc).__name__}: {exc}")
            else:
                try:
                    el.fill(real_text, timeout=10000)
                except Exception as exc:
                    fail("unexpected_dom", f"type {ref!r}: {type(exc).__name__}: {exc}")

        # read / done / give_up — no browser action needed; runner handles them.

    def _find_element(self, ref: str):
        """Locate the live page element matching a ref from our last snapshot.

        Accessibility-tree refs (a0, a1, …) are matched by position via a
        fresh flatten; element refs (el0, el1, …) are matched by index in the
        interactable query. Returns None if not found.
        """
        try:
            if ref.startswith("a"):
                idx = int(ref[1:])
                raw_tree = self._page.accessibility.snapshot()
                flat = self._flatten_tree(raw_tree or {})
                if idx < len(flat):
                    # Best-effort: locate by name/role using Playwright's
                    # getBy helpers; fall back to CSS selector.
                    node = flat[idx]
                    name = node.get("name", "")
                    role = node.get("role", "")
                    if name:
                        try:
                            return self._page.get_by_role(
                                role.lower(), name=name).first
                        except Exception:
                            pass
            elif ref.startswith("el"):
                idx = int(ref[2:])
                els = self._page.query_selector_all(
                    "a[href], button, input, select, textarea, [role='button'], "
                    "[role='link'], [role='textbox'], [role='checkbox']"
                )
                if idx < len(els):
                    return els[idx]
        except Exception:
            pass
        return None


# ---------------------------------------------------------------------------
# Success indicator checking (login gate)
# ---------------------------------------------------------------------------

def _check_success_indicators(page, indicators: tuple) -> bool:
    """Return True iff at least one success indicator from the profile holds."""
    for ind in indicators:
        try:
            kind = ind.get("type")
            if kind == "url_pattern":
                pattern = str(ind.get("value") or "")
                import fnmatch
                if fnmatch.fnmatch(page.url, pattern):
                    return True
            elif kind == "element":
                selector = str(ind.get("value") or "")
                if selector and page.query_selector(selector):
                    return True
            elif kind == "cookie":
                name = str(ind.get("value") or "")
                cookies = page.context.cookies()
                if any(c.get("name") == name for c in cookies):
                    return True
        except Exception:
            continue
    return False


# ---------------------------------------------------------------------------
# headless claude -p complete function (UNVERIFIED until deploy)
# ---------------------------------------------------------------------------

# Model id for per-step browser action decisions. Sonnet tier: login is
# mechanical (type/type/click) but open-ended navigation — finding a specific
# class on a timetable — needs real multi-step reasoning, where haiku loops on
# read. Sonnet 4.6 supports structured outputs (used below). Drop to
# claude-haiku-4-5 for cheaper, simpler sites; raise to opus for the hardest.
_MODEL = "claude-sonnet-4-6"
_API_URL = "https://api.anthropic.com/v1/messages"
_API_VERSION = "2023-06-01"

# Structured-output schema: one action object from the agent vocabulary. Forces
# the model to emit exactly one valid JSON action (no prose / markdown / native
# tool-call XML), keyed by "kind". Per-kind fields are all optional here; the
# browser_gate is the authority on which fields each kind needs.
_ACTION_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "required": ["kind"],
    "properties": {
        "kind": {"type": "string", "enum": [
            "read", "navigate", "click", "type", "propose_commit", "done", "give_up"]},
        "ref": {"type": "string"},
        "path": {"type": "string"},
        "expected_text": {"type": "string"},
        "expected_label": {"type": "string"},
        "text": {"type": "string"},
        "result": {"type": "string"},
        "reason": {"type": "string"},
        "summary": {"type": "string"},
        "price": {"type": "number"},
    },
}


def _http_post(url: str, headers: dict[str, str], body: bytes) -> bytes:
    """POST `body` to `url` and return the raw response bytes. Raises on any
    transport/HTTP error (urllib raises HTTPError for non-2xx). Kept tiny and
    injectable so _make_complete is testable without a network call."""
    import urllib.request  # noqa: PLC0415 — stdlib only; no new venv dependency

    req = urllib.request.Request(url, data=body, headers=headers, method="POST")
    with urllib.request.urlopen(req, timeout=60) as resp:  # noqa: S310 — fixed Anthropic URL
        return resp.read()


def _make_complete(api_key: str, *, transport=_http_post):
    """Return a `complete(system, user) -> str` backed by the Anthropic Messages
    API (design §5.7). The API key is delivered to this executor by the broker
    over DONNA_MODEL_KEY_FD — never via env, never via the CLI, never seen by
    Donna. `transport(url, headers, body) -> bytes` is injected so this is
    unit-testable without a network call.

    On ANY failure (no key, transport error, non-200, malformed body, empty
    text) it returns a `give_up` action string — the agent treats that as a
    safe terminal action and never guesses. Fail-closed everywhere (§3 inv. 6).
    """
    def _complete(system: str, user: str) -> str:
        if not api_key:
            return json.dumps({"kind": "give_up", "reason": "no model key available"})
        body = json.dumps({
            "model": _MODEL,
            "max_tokens": 1024,
            "system": system,
            "messages": [{"role": "user", "content": user}],
            # Force exactly one valid action object — no prose, no markdown, no
            # native tool-call XML. Haiku 4.5 supports structured outputs; this
            # makes the agent's output deterministic across any site/model.
            "output_config": {"format": {"type": "json_schema",
                                         "schema": _ACTION_SCHEMA}},
        }).encode("utf-8")
        headers = {
            "x-api-key": api_key,
            "anthropic-version": _API_VERSION,
            "content-type": "application/json",
        }
        try:
            raw = transport(_API_URL, headers, body)
            data = json.loads(raw)
            blocks = data.get("content") if isinstance(data, dict) else None
            if not isinstance(blocks, list):
                return json.dumps({"kind": "give_up", "reason": "model: no content blocks"})
            text = "".join(
                str(b.get("text", "")) for b in blocks
                if isinstance(b, dict) and b.get("type") == "text"
            ).strip()
            if not text:
                return json.dumps({"kind": "give_up", "reason": "model: empty response"})
            return text
        except Exception as exc:
            return json.dumps({"kind": "give_up",
                                "reason": f"model call failed: {type(exc).__name__}: {exc}"})

    return _complete


def _debug_tee(fn, debug_path):
    """Wrap a complete(system, user) callable so each call appends the page the
    model saw (the user prompt — sanitised, untrusted, no secrets) and what it
    returned to debug_path. Run dir is donna-broker-only ephemeral tmp; the
    agent only ever sees {{cred:*}} placeholders, so no credential is logged.
    Best-effort: a debug-write failure never affects the agent."""
    if debug_path is None:
        return fn

    def wrapped(system: str, user: str) -> str:
        out = fn(system, user)
        try:
            with open(debug_path, "a", encoding="utf-8") as f:
                f.write(json.dumps({"user": user[:6000], "out": out[:6000]}) + "\n")
        except Exception:
            pass
        return out

    return wrapped


def read_model_key() -> str:
    """Read the Anthropic API key the broker delivers over DONNA_MODEL_KEY_FD.

    Mirrors read_creds (a second inherited fd, same vault→pipe path). Returns
    "" if the fd is absent so the executor degrades to a fail-closed give_up
    rather than crashing — the broker only sets the fd for capabilities that
    declare creds.model_key. The key lives only here, in this subprocess.
    """
    fd_str = os.environ.get("DONNA_MODEL_KEY_FD")
    if fd_str is None:
        return ""
    fd = int(fd_str)
    data = b""
    while True:
        chunk = os.read(fd, 65536)
        if not chunk:
            break
        data += chunk
    os.close(fd)
    return data.decode("utf-8").strip()


# ---------------------------------------------------------------------------
# main — the live path. Playwright import lives HERE so module-level import
# never requires Playwright (enabling the pure-helper tests).
# ---------------------------------------------------------------------------

def main() -> None:
    params = read_params()
    creds = read_creds()
    model_key = read_model_key()

    site = str(params.get("site") or "").strip()
    goal = str(params.get("goal") or "").strip()
    phase = str(params.get("phase") or "plan").strip()
    max_price = params.get("max_price")          # optional int (pence)
    commit_token = params.get("commit_token")    # optional str
    # plan_summary is available for context but the agent sees it via goal.
    plan_summary = params.get("plan_summary", "")
    # Optional human-provided navigation hints to steer a hard-to-navigate site.
    hints = str(params.get("hints") or "").strip()

    if not site:
        fail("bad_params", "params.site is required")
    if not goal:
        fail("bad_params", "params.goal is required")
    if phase not in ("plan", "execute"):
        fail("bad_params", f"params.phase must be 'plan' or 'execute', got {phase!r}")

    # If a plan summary exists, prepend it to the goal so the execute phase
    # has the context from the recon phase.
    effective_goal = goal
    if plan_summary:
        effective_goal = f"{goal}\n\n[Plan context: {plan_summary}]"

    # Load site profile (fail-closed: exits if missing/malformed).
    profile = _load_profile(site)

    # Import Playwright HERE — not at module top-level.
    from playwright.sync_api import sync_playwright, TimeoutError as PwTimeout  # noqa: PLC0415

    # Bind the module globals the adapter methods reference: the real Playwright
    # TimeoutError (so expect_page timeouts are caught precisely) and the
    # tab-follow diagnostic sink (written next to agent_debug.jsonl).
    global PWTimeout, _TABFOLLOW_LOG
    PWTimeout = PwTimeout

    run_id = str(uuid.uuid4())
    run_dir = Path(os.environ.get("DONNA_RUN_DIR", "/tmp")) / f"browser_goal_{run_id}"
    run_dir.mkdir(parents=True, exist_ok=True)
    _TABFOLLOW_LOG = str(run_dir / "tabfollow.log")
    ledger_path = run_dir / "ledger.jsonl"

    now = time.monotonic

    ledger = browser_ledger.Ledger(ledger_path, run_id, now)
    ledger.run_header(
        site=site,
        goal=effective_goal,
        caps={"phase": phase,
              "max_price": max_price,
              "commit_token_provided": bool(commit_token)},
    )

    try:
        pw = sync_playwright().start()
    except Exception as exc:
        fail("browser_launch", f"playwright_init: {type(exc).__name__}: {exc}")

    try:
        browser = pw.chromium.launch(
            headless=True, channel="chromium-headless-shell"
        )
    except Exception as exc:
        pw.stop()
        fail("browser_launch", f"browser_launch: {type(exc).__name__}: {exc}")

    context = browser.new_context(viewport={"width": 1280, "height": 900})
    page = context.new_page()

    try:
        # Build the adapter. The allowlist and creds live inside it.
        adapter = _PlaywrightBrowser(
            page=page,
            context=context,
            allowlist=profile.allowlist,
            strictness=profile.network_strictness,
            creds=creds,
        )

        # --- Login ---
        try:
            page.goto(profile.login_url, timeout=30000, wait_until="domcontentloaded")
        except Exception as exc:
            fail("site_unavailable",
                 f"login page {profile.login_url!r} did not load: "
                 f"{type(exc).__name__}: {exc}")

        # Credential injection: the agent will navigate to the login page and
        # issue type actions with {{cred:username}}/{{cred:password}}.
        # The adapter's execute() substitutes the real values.
        # Here we check success_indicators to know when login has succeeded;
        # the agent drives the actual login steps.
        #
        # Run a short "login" phase first — max 15 actions, goal = "log in".
        login_goal = (
            f"Log in to {profile.login_url}. "
            f"You are already on the login page. "
            f"Find the username/email field and fill it with {{{{cred:username}}}}. "
            f"Find the password field and fill it with {{{{cred:password}}}}. "
            f"Submit the form. "
            f"Stop (done) when you see evidence of a successful login."
        )

        login_agent = browser_agent.Agent(
            goal=login_goal,
            phase="execute",
            complete=_debug_tee(_make_complete(model_key),
                                 run_dir / "agent_debug.jsonl"),
        )
        login_tokens = browser_token.TokenStore(now=now)
        login_gate = browser_gate.Gate(
            profile=profile,
            tokens=login_tokens,
            creds=creds,
            phase="execute",
        )
        login_ledger = browser_ledger.Ledger(
            run_dir / "login_ledger.jsonl", run_id + "_login", now
        )
        login_ledger.run_header(site=site, goal=login_goal,
                                caps={"phase": "execute", "login": True})

        login_result = browser_runner.run(
            browser=adapter,
            agent=login_agent,
            the_gate=login_gate,
            ledger=login_ledger,
            phase="execute",
            max_actions=20,
            commit_token=None,
        )

        # Verify login regardless of the agent's self-report (§7, fail-closed):
        # at least one explicit success_indicator from the profile must hold.
        if not _check_success_indicators(page, profile.success_indicators):
            # Agent thinks it's done but indicators don't hold.
            login_status = login_result.get("status", "")
            if login_status not in ("done",):
                fail("login_failed",
                     f"login agent ended with status={login_status!r}; "
                     f"no success indicator matched on {page.url!r}")
            # Even if agent said "done", check page state.
            fail("login_failed",
                 f"login completed but no success indicator matched on {page.url!r} "
                 f"— credentials may be wrong or the site changed")

        # --- Goal phase (plan or execute) ---
        tokens = browser_token.TokenStore(now=now)
        gate = browser_gate.Gate(
            profile=profile,
            tokens=tokens,
            creds=creds,
            phase=phase,
        )
        hint_block = (
            "HUMAN NAVIGATION HINTS — follow these as authoritative directions to "
            f"reach the goal (they override your own guesses about where to go):\n{hints}\n\n"
        ) if hints else ""
        goal_instruction = (
            f"{effective_goal}\n\n"
            f"{hint_block}"
            "Work toward the goal PURPOSEFULLY. These are general rules, not "
            "site-specific hints — let the goal above tell you WHAT to look for.\n"
            "MOVING AROUND: to go anywhere, CLICK a link or button you can see in "
            "the elements list (by its ref) — clicking follows the page's REAL "
            "link. Do NOT 'navigate' to a path/URL you GUESSED — you can't see real "
            "URLs, so a guess will fail or hit a wrong page. EXCEPTION: a relative "
            "path given to you in the HUMAN NAVIGATION HINTS above is trusted — you "
            "MAY navigate to it directly. Otherwise move only by clicking a visible "
            "element; read '_pagetext' to decide which link is relevant.\n"
            "READING: the element with ref '_pagetext' holds the page's visible "
            "text — read it to find the information the goal needs and to notice "
            "dead ends. If a page says 'not found' / 'error' or has no useful "
            "content, go back and try a different real link instead of repeating "
            "'read'.\n"
            "FINISHING: when you have found what the goal asks for, return 'done' "
            "with a concise result. If the goal would book, pay, or change "
            "something, use 'propose_commit', never act directly."
        )
        agent = browser_agent.Agent(
            goal=goal_instruction,
            phase=phase,
            complete=_debug_tee(_make_complete(model_key),
                                 run_dir / "agent_debug.jsonl"),
        )

        # Action cap: navigation needs room. Plan (read-only) gets a generous
        # budget; execute a bit more for the commit steps.
        max_actions = 80 if phase == "execute" else 60

        result = browser_runner.run(
            browser=adapter,
            agent=agent,
            the_gate=gate,
            ledger=ledger,
            phase=phase,
            max_actions=max_actions,
            commit_token=commit_token,
        )

        json.dump(result, sys.stdout)
        sys.stdout.flush()

    except SystemExit:
        raise
    except Exception as exc:
        fail("unexpected_error", f"{type(exc).__name__}: {exc}")
    finally:
        try:
            context.close()
        except Exception:
            pass
        try:
            browser.close()
        except Exception:
            pass
        try:
            pw.stop()
        except Exception:
            pass


if __name__ == "__main__":
    main()
