{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donna://schemas/notion_create_view.json",
  "title": "notion-create-view params",
  "type": "object",
  "additionalProperties": false,
  "required": ["data_source_id", "name", "type"],
  "properties": {
    "data_source_id": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "database_id": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "parent_page_id": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "type": {
      "type": "string",
      "enum": ["table", "board", "list", "calendar", "timeline", "gallery", "form", "chart", "map", "dashboard"]
    },
    "configure": {
      "type": "string",
      "maxLength": 5000
    }
  }
}
