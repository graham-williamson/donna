{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donna://schemas/notion_create_pages.json",
  "title": "notion-create-pages params",
  "type": "object",
  "additionalProperties": false,
  "required": ["parent", "title", "content"],
  "properties": {
    "parent": {
      "type": "object",
      "oneOf": [
        {
          "required": ["page_id"],
          "additionalProperties": false,
          "properties": {
            "page_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$"
            }
          }
        },
        {
          "required": ["database_id"],
          "additionalProperties": false,
          "properties": {
            "database_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$"
            }
          }
        }
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50000,
      "description": "§12.6 requires char count + first 200 chars in approval prompt"
    }
  }
}
