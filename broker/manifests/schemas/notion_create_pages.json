{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donna://schemas/notion_create_pages.json",
  "title": "notion-create-pages params",
  "type": "object",
  "additionalProperties": false,
  "required": ["parent", "pages"],
  "properties": {
    "parent": {
      "type": "object",
      "oneOf": [
        {
          "required": ["type", "page_id"],
          "additionalProperties": false,
          "properties": {
            "type": {"type": "string", "enum": ["page_id"]},
            "page_id": {"type": "string", "minLength": 32, "maxLength": 40}
          }
        },
        {
          "required": ["type", "database_id"],
          "additionalProperties": false,
          "properties": {
            "type": {"type": "string", "enum": ["database_id"]},
            "database_id": {"type": "string", "minLength": 32, "maxLength": 40}
          }
        },
        {
          "required": ["type", "data_source_id"],
          "additionalProperties": false,
          "properties": {
            "type": {"type": "string", "enum": ["data_source_id"]},
            "data_source_id": {"type": "string", "minLength": 10, "maxLength": 200}
          }
        }
      ]
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "properties": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [{"type": "string"}, {"type": "number"}, {"type": "null"}]
            }
          },
          "content": {"type": "string", "maxLength": 50000},
          "icon": {"type": "string", "maxLength": 500},
          "cover": {"type": "string", "maxLength": 500}
        }
      }
    }
  }
}
