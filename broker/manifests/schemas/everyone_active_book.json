{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donna://schemas/everyone_active_book.json",
  "title": "everyone_active.book_class params",
  "type": "object",
  "additionalProperties": false,
  "required": ["centre_id", "class_id", "date"],
  "properties": {
    "centre_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,40}$",
      "description": "Everyone Active centre slug (e.g. 'chesham-moor-gym-and-swim')"
    },
    "class_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{2,64}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date in Europe/London calendar day terms"
    },
    "start_time": {
      "type": "string",
      "pattern": "^[0-2][0-9]:[0-5][0-9]$"
    }
  }
}
