{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donna://schemas/gmail_create_draft.json",
  "title": "gmail.create_draft params",
  "type": "object",
  "additionalProperties": false,
  "required": ["to", "subject", "body"],
  "properties": {
    "to": {
      "type": "array",
      "items": { "type": "string", "format": "email", "maxLength": 254 },
      "minItems": 1,
      "maxItems": 1
    },
    "cc": {
      "type": "array",
      "items": { "type": "string", "format": "email", "maxLength": 254 },
      "maxItems": 1
    },
    "bcc": {
      "type": "array",
      "items": { "type": "string", "format": "email", "maxLength": 254 },
      "maxItems": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000
    },
    "htmlBody": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000
    }
  }
}
